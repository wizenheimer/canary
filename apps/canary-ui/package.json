{
  "name": "@usecanary/ui",
  "version": "0.2.1",
  "private": false,
  "type": "module",
  "description": "Local web viewer for canary sessions — reads results.json, lists/organizes/searches recorded sessions, styled after the self-contained report.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "canary",
    "session-viewer",
    "playwright",
    "qa",
    "report"
  ],
  "homepage": "https://github.com/usecanary/canary#readme",
  "bugs": "https://github.com/usecanary/canary/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usecanary/canary.git",
    "directory": "apps/canary-ui"
  },
  "bin": {
    "canary-viewer": "./bin/viewer.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "start": "node dist/server/entry.mjs",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .astro coverage .turbo"
  },
  "devDependencies": {
    "@astrojs/node": "^10.1.3",
    "@astrojs/react": "^5.0.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "^6.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "nuqs": "^2.8.9",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
