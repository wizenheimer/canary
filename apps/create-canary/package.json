  },
  "devDependencies": {
    "@usecanary/config": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "esbuild": "^0.27.4",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0"
  }
}
