{
  "name": "create-canary",
  "version": "0.4.2",
  "type": "module",
  "description": "Set up canary — browser automation + recorded QA sessions. Run `npm create canary`.",
  "license": "MIT",
  "keywords": [
    "canary",
    "create",
    "installer",
    "browser-automation",
    "qa"
  ],
  "homepage": "https://github.com/usecanary/canary#readme",
  "bugs": "https://github.com/usecanary/canary/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usecanary/canary.git",
    "directory": "apps/create-canary"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "create-canary": "./dist/cli.js"
  },
  "files": [
