{
  "name": "@canary/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Canary daemon — long-running Playwright host with QuickJS sandbox. Embedded into @canary/browser at build time.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm bundle && pnpm bundle:sandbox-client",
    "bundle": "esbuild src/daemon.ts --bundle --platform=node --format=esm --outfile=dist/daemon.bundle.mjs --external:playwright --external:quickjs-emscripten --external:@jitl/*",
    "bundle:sandbox-client": "tsx scripts/bundle-sandbox-client.ts",
    "dev": "tsx src/daemon.ts",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"(no eslint configured yet for @canary/daemon)\"",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@canary/protocol": "workspace:*",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "quickjs-emscripten": "^0.32.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@canary/typescript-config": "workspace:*",
    "@types/node": "^24.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
